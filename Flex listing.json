{
  "type": "bubble",
  "header": {
    "type": "box",
    "layout": "vertical",
    "contents": [],
    "paddingAll": "0px"
  },
  "hero": {
    "type": "box",
    "layout": "horizontal",
    "contents": [
      {
        "type": "image",
        "url": "__COVER_MAIN__",
        "size": "full",
        "aspectMode": "cover",
        "aspectRatio": "150:196",
        "gravity": "center",
        "flex": 1
      },
      {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "image",
            "url": "__COVER_SUB1__",
            "size": "full",
            "aspectMode": "cover",
            "aspectRatio": "150:98",
            "gravity": "center"
          },
          {
            "type": "image",
            "url": "__COVER_SUB2__",
            "size": "full",
            "aspectMode": "cover",
            "aspectRatio": "150:98",
            "gravity": "center"
          }
        ],
        "flex": 1
      },
      {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "text",
            "text": "__STATUS_BADGE__",
            "size": "xxs",
            "color": "#F0F0F0",
            "align": "center",
            "gravity": "center",
            "weight": "bold"
          }
        ],
        "backgroundColor": "#10B981",
        "paddingAll": "2px",
        "paddingStart": "4px",
        "paddingEnd": "4px",
        "flex": 0,
        "position": "absolute",
        "offsetStart": "18px",
        "offsetTop": "18px",
        "cornerRadius": "100px",
        "width": "58px",
        "height": "25px",
        "borderWidth": "normal",
        "borderColor": "#2ECC71",
        "justifyContent": "center"
      }
    ],
    "borderWidth": "none",
    "background": {
      "type": "linearGradient",
      "angle": "180deg",
      "startColor": "#999999",
      "endColor": "#D4D4D4"
    }
  },
  "body": {
    "type": "box",
    "layout": "vertical",
    "contents": [
      {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "text",
            "text": "__PROJECT_NAME__",
            "size": "md",
            "color": "#2B2B2B",
            "weight": "bold",
            "wrap": true
          },
          {
            "type": "text",
            "text": "__PROJECT_NAME_EN__",
            "size": "xs",
            "color": "#71717a",
            "wrap": true,
            "margin": "xs"
          },
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "__PRICE__ บาท",
                "size": "lg",
                "color": "#000000",
                "weight": "bold",
                "flex": 1
              }
            ],
            "margin": "md"
          }
        ]
      },
      {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "ค่าส่วนกลาง:",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 2
              },
              {
                "type": "text",
                "text": "__COMMON_FEE__",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 4,
                "wrap": true
              }
            ]
          },
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "ที่อยู่:",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 2
              },
              {
                "type": "text",
                "text": "__HOUSE_NO__",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 4,
                "wrap": true
              }
            ],
            "margin": "sm"
          },
          {
            "type": "separator",
            "color": "#B3B3B3",
            "margin": "md"
          },
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "Owner:",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 2
              },
              {
                "type": "text",
                "text": "__OWNER_NAME__",
                "color": "#2B2B2B",
                "size": "xs",
                "weight": "bold",
                "flex": 4,
                "wrap": true
              }
            ],
            "margin": "md"
          },
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "Code Listing:",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 2
              },
              {
                "type": "text",
                "text": "__PROPERTY_CODE__",
                "color": "#2B2B2B",
                "size": "xs",
                "weight": "bold",
                "flex": 4,
                "wrap": true
              }
            ],
            "margin": "sm"
          },
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "เบอร์โทร:",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 2
              },
              {
                "type": "text",
                "text": "__PHONE__",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 4,
                "wrap": true,
                "action": {
                  "type": "uri",
                  "label": "Call",
                  "uri": "__PHONE_TEL__"
                }
              }
            ],
            "margin": "sm"
          },
          {
            "type": "box",
            "layout": "horizontal",
            "contents": [
              {
                "type": "text",
                "text": "Line ID:",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 2
              },
              {
                "type": "text",
                "text": "__LINE_ID__",
                "color": "#2B2B2B",
                "size": "xs",
                "flex": 4,
                "wrap": true,
                "action": {
                  "type": "uri",
                  "label": "LINE",
                  "uri": "__LINE_URL__"
                }
              }
            ],
            "margin": "sm"
          }
        ],
        "borderColor": "#D4D4D4",
        "cornerRadius": "10px",
        "margin": "xl",
        "backgroundColor": "#F8F9FA",
        "paddingAll": "13px",
        "spacing": "xl"
      },
      {
        "type": "box",
        "layout": "vertical",
        "contents": [
          {
            "type": "button",
            "action": {
              "type": "uri",
              "label": "Call",
              "uri": "__PHONE_TEL__"
            },
            "color": "#2B2B2B"
          },
          {
            "type": "button",
            "action": {
              "type": "uri",
              "label": "Location",
              "uri": "__MAP_URL__"
            },
            "style": "primary",
            "color": "#5C4E4E",
            "height": "sm",
            "margin": "xs"
          },
          {
            "type": "button",
            "action": {
              "type": "uri",
              "label": "รายละเอียดเพิ่มเติม",
              "uri": "__DETAIL_URL__"
            },
            "style": "primary",
            "color": "#988686",
            "margin": "sm",
            "height": "sm"
          }
        ],
        "margin": "xl"
      }
    ],
    "paddingAll": "20px",
    "backgroundColor": "#D4D4D4"
  },
  "styles": {
    "header": {
      "separator": true
    },
    "hero": {
      "separator": true
    }
  }
}
